{
  "version": "0.0.5",
  "keywords": [
    "strapi",
    "plugin",
    "ownership",
    "guard",
    "data",
    "RBAC",
    "access control",
    "data ownership",
    "data access",
    "access"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "@koa/router": "^13.1.0",
    "@strapi/design-system": "^2.0.0-rc.21",
    "@strapi/icons": "^2.0.0-rc.21",
    "axios": "^1.8.4",
    "koa-body": "^6.0.1",
    "react-intl": "^7.1.10"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "^5.12.3",
    "@strapi/typescript-utils": "^5.12.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "prettier": "^3.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "styled-components": "^6.1.17",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "^5.12.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "styled-components": "^6.1.17"
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi-plugin-data-ownership-guard",
    "displayName": "Data Ownership Guard",
    "description": "This plugin is used to protect the data from users who are not the owner of the data."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abolfazlyounesi/strapi-plugin-data-ownership-guard.git"
  },
  "bugs": {
    "url": "https://github.com/abolfazlyounesi/strapi-plugin-data-ownership-guard/issues"
  },
  "homepage": "https://github.com/abolfazlyounesi/strapi-plugin-data-ownership-guard#readme",
  "name": "strapi-plugin-data-ownership-guard",
  "description": "",
  "license": "MIT",
  "author": "Abolfazl Younesi <abolfazl.younesi277@gmail.com>"
}
